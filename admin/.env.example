SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-bytes

# Existing mobile/Expo names are also accepted by the mobile API:
# EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Used only by npm run bootstrap:admin
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-long-random-password
ADMIN_BOOTSTRAP_NAME=Parking Admin

# Mobile API
MOBILE_API_ENABLED=true
MOBILE_API_ALLOWED_ORIGINS=https://flowaux.in,https://www.flowaux.in
MOBILE_API_RATE_LIMIT_MODE=dry-run
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
