API_BASE_URL=https://lotzi.in/api/v1
APP_ENV=development
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
AUTH_REDIRECT_SCHEME=urbanparking
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
GOOGLE_MAPS_API_KEY=your-android-google-maps-api-key
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_UPLOAD_FOLDER=lotzi/listing-photos
USE_MOCK_GEO=false

# Vercel server-only env vars for /api/v1/geo-discovery/search
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GEO_DISCOVERY_ALLOWED_ORIGIN=*
MOBILE_API_ENABLED=true
MOBILE_API_ALLOWED_ORIGINS=https://lotzi.in,https://www.lotzi.in
MOBILE_API_RATE_LIMIT_MODE=dry-run
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
NOTIFICATION_WORKER_SECRET=your-notification-worker-secret
NOTIFICATION_DEVICE_TOKEN_SECRET=32-byte-or-longer-token-encryption-secret
FCM_SERVICE_ACCOUNT_JSON={"type":"service_account"}
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=Lotzi <notifications@lotzi.in>
